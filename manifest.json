{
  "manifest_version": 3,
  "name": "Eblo.id Tweaker",
  "version": "1.0",
  "content_scripts": [
    {
      "matches": ["https://eblo.id/*"],
      "css": ["src/styles.css"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/inject.js"],
      "matches": ["https://eblo.id/*"]
    }
  ]
}